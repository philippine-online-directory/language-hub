// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  username  String
  createdAt DateTime @default(now())
  role      Role     @default(LEARNER)
  reminderType ReminderType?
  lastReminderSentAt DateTime?

  contributions Translation[]
  createdSets   VocabSet[]
  gameScores    GameSession[]
}

model Language {
  id                 String  @id @default(cuid())
  name               String  @unique
  speakerCount       Int?    @default(0)
  isoCode            String  @unique
  preservationNote   String?
  culturalBackground String?

  translations Translation[]
  vocabSets    VocabSet[]
}

model Translation {
  id                String    @id @default(cuid())
  wordText          String
  ipa               String?
  englishDefinition String
  exampleSentence   String
  status            Status    @default(UNVERIFIED)
  createdAt         DateTime  @default(now())
  publishedAt       DateTime?
  audioUrl          String?
  partOfSpeech      String?
  usedAsWordOfTheDay Boolean  @default(false)

  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  setWords SetWord[]
  wordOfTheDays WordOfTheDay[]
}

model VocabSet {
  id          String  @id @default(cuid())
  name        String  @unique
  description String
  isPublic    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  setWords     SetWord[]
  gameSessions GameSession[]
}

model SetWord {
  translationId String
  vocabSetId    String

  translation Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)
  vocabSet    VocabSet    @relation(fields: [vocabSetId], references: [id], onDelete: Cascade)

  @@id([translationId, vocabSetId])
}

model GameSession {
  id        String   @id @default(cuid())
  gameType  GameType
  score     Int
  duration  Float
  createdAt DateTime @default(now())

  userId     String
  vocabSetId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabSet VocabSet @relation(fields: [vocabSetId], references: [id], onDelete: Cascade)
}

model WordOfTheDay {
  id            String      @id @default("current")  
  displayDate   DateTime    @db.Date                 
  
  translationId String
  translation   Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)
}

enum ReminderType {
  WORD
  CHECKWORD
}

enum Role {
  LEARNER
  ADMIN
}

enum Status {
  UNVERIFIED
  VERIFIED
}

enum GameType {
  FLASHCARD
  MATCHING
  WRITING
}
