// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  password           String
  username           String
  createdAt          DateTime      @default(now())
  role               Role          @default(LEARNER)
  reminderType       ReminderType?
  lastReminderSentAt DateTime?

  contributions         Translation[] @relation("PrimaryAuthor")
  secondaryTranslations Translation[] @relation("secondaryAuthors")

  createdSets VocabSet[]
  gameScores  GameSession[]

  submittedRequests TranslationUpdateRequest[]
  importBatches     ImportBatch[]              @relation("ImportBatchUploader")
  reviewedBatches   ImportBatch[]              @relation("ImportBatchReviewer")
}

model Language {
  id                 String  @id @default(cuid())
  name               String  @unique
  speakerCount       Int?
  isoCode            String? @unique
  slug               String  @unique
  preservationNote   String?
  culturalBackground String?

  completionCount Int @default(0)

  translations  Translation[]
  vocabSets     VocabSet[]
  importBatches ImportBatch[]
}

model Translation {
  id                 String    @id @default(cuid())
  wordText           String
  ipa                String?
  englishDefinition  String
  exampleSentence    String?
  status             Status    @default(UNVERIFIED)
  createdAt          DateTime  @default(now())
  publishedAt        DateTime?
  audioUrl           String?
  partOfSpeech       String?
  usedAsWordOfTheDay Boolean   @default(false)
  usageComment       String?

  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  // Primary author
  authorId String
  author   User   @relation("PrimaryAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // Secondary authors
  secondaryAuthors User[] @relation("secondaryAuthors")

  updateRequests TranslationUpdateRequest[]

  setWords      SetWord[]
  wordOfTheDays WordOfTheDay[]
  commonWord    CommonWord?      @relation(fields: [commonWordId], references: [id])
  commonWordId  Int?
  importRows    ImportBatchRow[]
}

model ImportBatch {
  id              String            @id @default(cuid())
  fileName        String
  status          ImportBatchStatus @default(PENDING_REVIEW)
  rightsConfirmed Boolean           @default(false)
  totalRows       Int               @default(0)
  importedRows    Int               @default(0)
  skippedRows     Int               @default(0)
  rejectedRows    Int               @default(0)
  createdAt       DateTime          @default(now())
  reviewedAt      DateTime?

  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation("ImportBatchUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  reviewedById String?
  reviewedBy   User?   @relation("ImportBatchReviewer", fields: [reviewedById], references: [id])

  rows ImportBatchRow[]
}

model ImportBatchRow {
  id                String          @id @default(cuid())
  rowNumber         Int
  wordText          String?
  englishDefinition String?
  ipa               String?
  exampleSentence   String?
  partOfSpeech      String?
  usageComment      String?
  status            ImportRowStatus
  errorMessage      String?

  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  translationId String?
  translation   Translation? @relation(fields: [translationId], references: [id], onDelete: SetNull)
}

model TranslationUpdateRequest {
  id            String      @id @default(cuid())
  translationId String
  translation   Translation @relation(fields: [translationId], references: [id])
  submittedById String
  submittedBy   User        @relation(fields: [submittedById], references: [id])
  languageId    String

  proposedData Json
  createdAt    DateTime @default(now())
}

model VocabSet {
  id          String  @id @default(cuid())
  name        String  @unique
  description String
  isPublic    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  setWords     SetWord[]
  gameSessions GameSession[]
}

model SetWord {
  translationId String
  vocabSetId    String

  translation Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)
  vocabSet    VocabSet    @relation(fields: [vocabSetId], references: [id], onDelete: Cascade)

  @@id([translationId, vocabSetId])
}

model GameSession {
  id        String   @id @default(cuid())
  gameType  GameType
  score     Int
  duration  Float
  createdAt DateTime @default(now())

  userId     String
  vocabSetId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabSet VocabSet @relation(fields: [vocabSetId], references: [id], onDelete: Cascade)
}

model WordOfTheDay {
  id          String   @id @default("current")
  displayDate DateTime @db.Date

  translationId String
  translation   Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)
}

model CommonWord {
  id   Int    @id @default(autoincrement())
  word String

  translations Translation[]
}

model GuestEmailSubscription {
  id               String   @id @default(cuid())
  email            String   @unique
  unsubscribeToken String   @unique @default(cuid())
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
}

enum ReminderType {
  WORD
  CHECKWORD
}

enum Role {
  LEARNER
  ADMIN
}

enum Status {
  UNVERIFIED
  VERIFIED
}

enum ImportBatchStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ROLLED_BACK
}

enum ImportRowStatus {
  IMPORTED
  SKIPPED_DUPLICATE
  INVALID
  REJECTED
  ROLLED_BACK
}

enum GameType {
  FLASHCARD
  MATCHING
  WRITING
}
